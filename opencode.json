{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "chrome-devtools-mcp": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true
    },
    "gopls-mcp-server": {
      "type": "local",
      "command": ["go", "run", "golang.org/x/tools/gopls@latest", "mcp"],
      "enabled": true
    },
    "heroui-react": {
      "type": "local",
      "command": ["npx", "-y", "@heroui/react-mcp"],
      "enabled": true
    },
    "codebase-memory-mcp": {
      "type": "local",
      "command": ["C:\\Users\\86198\\AppData\\Local\\Programs\\codebase-memory-mcp\\codebase-memory-mcp.exe"],
      "enabled": true
    }
  }
}
